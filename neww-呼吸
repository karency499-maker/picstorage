                const correctText = point.question.options[correctIndex];
                const correctLetter = String.fromCharCode(65 + correctIndex);
                
                detailReport += `\n【考点${point.id}】${point.title}\n`;
                detailReport += `  - 单选: ${qOk}\n`;
                detailReport += `    医生选择: ${userChoiceLetter}. ${userChoiceText}\n`;
                detailReport += `    正确答案: ${correctLetter}. ${correctText}\n`;
                detailReport += `--------------------------`;
            });
          
// 第二步：把上面拼好的“详细记录”塞进最终的 messageText
const messageText = `📋 启动期新医生入驻考核报告
--------------------------
👤 姓名：${userName}
📊 总分：${score} 分
🏁 结果：${passed ? '✅ 考核通过' : '❌ 未通过'}
⏰ 时间：${new Date().toLocaleString()}
--------------------------
📝 答题明细（考试记录）：
${detailReport}`;

// --- 修改结束，下面继续执行你原有的 fetch 发送逻辑 ---

            try {
                // 使用 no-cors 模式绕过浏览器拦截，直接发送给机器人
                fetch(webhookUrl, {
                    method: 'POST',
