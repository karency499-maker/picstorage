        // ==================== 用户考试流程 ====================
        function startExam() {
            const userName = document.getElementById('userName').value.trim();
            if (!userName) {
                alert('请输入您的姓名');
                return;
            }

            // 1. 检查是否已经参加过考试（维持老用户直接看成绩逻辑）
            const existingRecord = examRecords.find(record => record.userName === userName);
            if (existingRecord) {
                // 显示历史成绩
                showHistoricalResult(existingRecord);
                return;
            }

            // 2. 检查是否有未完成的进度（断点续传逻辑）
            const savedProgressStr = localStorage.getItem('medical_exam_progress');
            if (savedProgressStr) {
                const savedProgress = JSON.parse(savedProgressStr);
                // 只有当本地进度对应的也是当前输入的名字时，才提示恢复
                if (savedProgress.userName === userName) {
                    if (confirm('检测到您有未完成的测试进度，是否从上次断点继续？\n（若选择取消，将清空并重新开始测试）')) {
                        restoreProgress(savedProgress);
                        return;
                    } else {
                        localStorage.removeItem('medical_exam_progress');
                    }
                }
            }

            // 3. 开始全新测试
            currentUserName = userName;
            userAnswers = [];
            currentPointIndex = 0;
            isRetaking = false;
            currentSection = 'list';

            saveProgress(); // 存入初始进度

            document.getElementById('loginSection').classList.add('hidden');
            document.getElementById('examListSection').classList.remove('hidden');
            updateExamPointsList();
        }

        // ==================== 断点续传保存/恢复与进度条 ====================

        // 保存当前进度
        function saveProgress() {
            const progress = {
                userName: currentUserName,
                currentPointIndex: currentPointIndex,
                userAnswers: userAnswers,
                currentSection: currentSection
            };
            localStorage.setItem('medical_exam_progress', JSON.stringify(progress));
        }

        // 恢复进度
        function restoreProgress(progress) {
            currentUserName = progress.userName;
            currentPointIndex = progress.currentPointIndex;
            userAnswers = progress.userAnswers || [];
            currentSection = progress.currentSection || 'list';

            document.getElementById('loginSection').classList.add('hidden');

            // 根据保存的环节跳转
            if (currentSection === 'list') {
                document.getElementById('examListSection').classList.remove('hidden');
                updateExamPointsList();
            } else if (currentSection === 'learning') {
                showLearning(currentPointIndex);
            } else if (currentSection === 'question') {
                startQuestion();
            }
        }

        // 更新进度条 UI
        function updateProgressBar() {
            const totalPoints = examPoints.length;
            // 计算完成的百分比：做完一个考点就累加 10% (假设共10个点)
            let percent = Math.floor((currentPointIndex / totalPoints) * 100);
            
            document.getElementById('progressBarFill').style.width = percent + '%';
            document.getElementById('progressText').textContent = percent + '%';
        }

